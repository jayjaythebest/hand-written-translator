rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Projects
    match /projects/{projectId} {
      allow read, create, delete: if true;
      allow update: if false;
    }

    // Project images (contains compressed base64 + status)
    match /projectImages/{imageId} {
      allow read, create, delete: if true;
      allow update: if true; // needed for status transitions by the pipeline
    }

    // Project records (extracted data, editable by user)
    match /projectRecords/{recordId} {
      allow read, create, delete: if true;
      allow update: if true; // needed for inline editing
    }

    // Legacy expenses collection (kept for backward compatibility)
    match /expenses/{expenseId} {
      allow read, create, delete: if true;
      allow update: if false;
    }
  }
}
